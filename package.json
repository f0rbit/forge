{
  "name": "@f0rbit/forge",
  "version": "0.4.0",
  "description": "Functional, composition-first TypeScript game engine with PIXI v8 renderer adapter, deterministic ECS, action-stream replays, and corpus-backed persistence.",
  "license": "MIT",
  "author": "Tom",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/f0rbit/forge.git"
  },
  "homepage": "https://github.com/f0rbit/forge#readme",
  "bugs": {
    "url": "https://github.com/f0rbit/forge/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "PLAN.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pixi": {
      "types": "./dist/pixi/index.d.ts",
      "import": "./dist/pixi/index.js"
    },
    "./debug": {
      "types": "./dist/debug/index.d.ts",
      "import": "./dist/debug/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./presets": {
      "types": "./dist/presets/index.d.ts",
      "import": "./dist/presets/index.js"
    },
    "./grid": {
      "types": "./dist/grid/index.d.ts",
      "import": "./dist/grid/index.js"
    },
    "./light": {
      "types": "./dist/pixi/light/index.d.ts",
      "import": "./dist/pixi/light/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && rolldown -c && tsc -p tsconfig.build.json",
    "build:watch": "rolldown -c --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check:determinism": "bun tools/no-throws.ts",
    "docs:install": "cd docs && bun install",
    "docs:dev": "cd docs && bun run dev",
    "docs:build": "cd docs && bun run build",
    "docs:preview": "cd docs && bun run preview"
  },
  "dependencies": {
    "@f0rbit/corpus": "^0.3.5",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "pixi.js": "^8"
  },
  "peerDependenciesMeta": {
    "pixi.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.0",
    "pixi.js": "^8",
    "rolldown": "^1.0.0-rc.18",
    "typescript": "^5.6.0"
  }
}
